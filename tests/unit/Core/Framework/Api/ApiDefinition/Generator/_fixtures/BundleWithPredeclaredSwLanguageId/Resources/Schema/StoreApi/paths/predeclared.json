    "paths": {
        "/predeclared-by-name": {
            "get": {
                "tags": ["Predeclared"],
                "summary": "Operation that already declares sw-language-id inline by name",
                "operationId": "readPredeclaredByName",
                "parameters": [
                    {
                        "name": "sw-language-id",
                        "in": "header",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "pattern": "^[0-9a-f]{32}$"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    }
                }
            }
        },
