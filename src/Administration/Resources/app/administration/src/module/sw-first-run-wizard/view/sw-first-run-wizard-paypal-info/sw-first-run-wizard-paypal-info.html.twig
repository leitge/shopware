{% block sw_first_run_wizard_paypal_info %}
<div class="sw-first-run-wizard-paypal">
    <div
        v-if="!isInstallingPlugin"
        class="sw-first-run-wizard-paypal-info"
    >
        <div
            v-if="pluginInstallationFailed"
            class="sw-first-run-wizard-paypal__error"
        >
            <mt-banner
                :title="pluginError.title"
                variant="critical"
            >
                {{ pluginError }}
            </mt-banner>
        </div>

        <img
            class="sw-first-run-wizard-paypal-info__icon"
            :src="assetFilter('/administration/administration/static/img/paypal-official-logo.svg')"
            alt=""
        >

        <h3 class="headline">
            {{ $t('sw-first-run-wizard.paypalInfo.headline') }}
        </h3>

        <div class="paymethods">
            <div class="paymethod">
                <mt-icon
                    name="regular-check-circle"
                    size="12px"
                />
                <span>{{ $t('sw-first-run-wizard.paypalInfo.paymethod.paypal') }}</span>
            </div>
            <div class="paymethod">
                <mt-icon
                    name="regular-check-circle"
                    size="12px"
                />
                <span>{{ $t('sw-first-run-wizard.paypalInfo.paymethod.debit') }}</span>
            </div>
            <div class="paymethod">
                <mt-icon
                    name="regular-check-circle"
                    size="12px"
                />
                <span>{{ $t('sw-first-run-wizard.paypalInfo.paymethod.creditcard') }}</span>
            </div>
            <div class="paymethod">
                <mt-icon
                    name="regular-check-circle"
                    size="12px"
                />
                <span>{{ $t('sw-first-run-wizard.paypalInfo.paymethod.invoice') }}**</span>
            </div>
        </div>

        <div class="disclaimer">
            <p>{{ $t('sw-first-run-wizard.paypalInfo.disclaimerLineOne') }}</p>
            <p>{{ $t('sw-first-run-wizard.paypalInfo.disclaimerLineTwo') }}</p>
        </div>
    </div>

    <div
        v-else
        class="sw-first-run-wizard-paypal-install"
    >
        <sw-loader size="48px" />

        <p
            class="sw-loader-info-text"
            v-html="$t('sw-first-run-wizard.paypalInstall.loadingMessage')"
        ></p>
    </div>
</div>
{% endblock %}
