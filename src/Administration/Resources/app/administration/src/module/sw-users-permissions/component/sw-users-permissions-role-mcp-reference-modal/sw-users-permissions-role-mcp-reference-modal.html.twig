{% block sw_users_permissions_role_mcp_reference_modal %}
<sw-modal
    class="sw-users-permissions-role-mcp-reference-modal"
    :title="$t('sw-users-permissions.roles.mcpModal.title')"
    @modal-close="closeModal"
>
    <div class="sw-users-permissions-role-mcp-reference-modal__content">
    {% block sw_users_permissions_role_mcp_reference_modal_content %}
    {% block sw_users_permissions_role_mcp_reference_modal_save_reminder %}
        <mt-banner
            v-if="hasPreselected"
            variant="info"
            class="sw-users-permissions-role-mcp-reference-modal__save-reminder"
        >
            {{ $t('sw-users-permissions.roles.mcpModal.saveReminder') }}
        </mt-banner>
    {% endblock %}

    {% block sw_users_permissions_role_mcp_reference_modal_toolbar %}
        <div class="sw-users-permissions-role-mcp-reference-modal__toolbar">
            <mt-select
                v-model="viewMode"
                class="sw-users-permissions-role-mcp-reference-modal__toolbar-viewmode-select"
                :options="filterOptions"
                :small="true"
            />

            <mt-button
                v-if="allMissingStatic.length > 0"
                size="small"
                variant="secondary"
                @click="grantAllMissing"
            >
                {{ $t('sw-users-permissions.roles.mcpModal.grantAllMissing') }}
            </mt-button>
        </div>
    {% endblock %}

    {% block sw_users_permissions_role_mcp_reference_modal_legend %}
        <div class="sw-users-permissions-role-mcp-reference-modal__legend">
            <span class="sw-users-permissions-role-mcp-reference-modal__legend-label">
                {{ $t('sw-users-permissions.roles.mcpModal.legendLabel') }}
            </span>

            <mt-badge
                v-tooltip="$t('sw-users-permissions.roles.mcpModal.legendGrantedHint')"
                class="sw-users-permissions-role-mcp-reference-modal__privilege-chip is--granted"
                variant="positive"
            >
                {{ $t('sw-users-permissions.roles.mcpModal.legendGranted') }}
            </mt-badge>

            <mt-badge
                v-tooltip="$t('sw-users-permissions.roles.mcpModal.legendMissingHint')"
                class="sw-users-permissions-role-mcp-reference-modal__privilege-chip is--missing"
                variant="critical"
            >
                {{ $t('sw-users-permissions.roles.mcpModal.legendMissing') }}
            </mt-badge>

            <mt-badge
                v-tooltip="$t('sw-users-permissions.roles.mcpModal.legendDynamicHint')"
                class="sw-users-permissions-role-mcp-reference-modal__privilege-chip is--dynamic"
                variant="neutral"
            >
                {{ $t('sw-users-permissions.roles.mcpModal.legendDynamic') }}
            </mt-badge>
        </div>
    {% endblock %}
    </div>

    {% block sw_users_permissions_role_mcp_reference_modal_loading %}
    <mt-loader v-if="isLoading" />
    {% endblock %}

    {% block sw_users_permissions_role_mcp_reference_modal_rows %}
    <template v-if="!isLoading">
        <template v-if="displayRows.length > 0">
            <div
                v-for="row in displayRows"
                :key="row.label"
                class="sw-users-permissions-role-mcp-reference-modal__row"
            >
                {% block sw_users_permissions_role_mcp_reference_modal_row_label %}
                <span class="sw-users-permissions-role-mcp-reference-modal__row-label">
                    {{ row.label }}
                </span>
                {% endblock %}

                {% block sw_users_permissions_role_mcp_reference_modal_row_chips %}
                <div class="sw-users-permissions-role-mcp-reference-modal__row-chips">
                    <mt-badge
                        v-for="chip in row.chips"
                        :key="chip.text"
                        v-tooltip="chip.isDynamic ? $t('sw-users-permissions.roles.mcpModal.dynamicPrivilegeHint') : ''"
                        class="sw-users-permissions-role-mcp-reference-modal__privilege-chip"
                        :class="{
                            'is--granted': !chip.isDynamic && chip.isGranted,
                            'is--missing': !chip.isDynamic && !chip.isGranted,
                            'is--dynamic': chip.isDynamic,
                        }"
                        :variant="getBadgeVariant(chip)"
                    >
                        {{ chip.text }}
                    </mt-badge>
                </div>
                {% endblock %}

                {% block sw_users_permissions_role_mcp_reference_modal_row_grant %}
                <mt-button
                    v-if="row.hasMissingStatic"
                    size="small"
                    variant="primary"
                    ghost
                    class="sw-users-permissions-role-mcp-reference-modal__row-grant"
                    @click="grantRow(row)"
                >
                    {{ $t('sw-users-permissions.roles.mcpModal.grant') }}
                </mt-button>
                {% endblock %}
            </div>
        </template>

        {% block sw_users_permissions_role_mcp_reference_modal_empty %}
        <mt-empty-state
            v-else
            :icon="$route.meta.$module.icon"
            :headline="$t('sw-users-permissions.roles.mcpModal.noToolsHeadline')"
            :description="$t('sw-users-permissions.roles.mcpModal.noToolsDescription')"
        />
        {% endblock %}
    </template>
    {% endblock %}

    {% endblock %}

    {% block sw_users_permissions_role_mcp_reference_modal_footer %}
    <template #modal-footer>
        <mt-button
            variant="primary"
            @click="closeModal"
        >
            {{ $t('global.default.close') }}
        </mt-button>
    </template>
    {% endblock %}
</sw-modal>
{% endblock %}
