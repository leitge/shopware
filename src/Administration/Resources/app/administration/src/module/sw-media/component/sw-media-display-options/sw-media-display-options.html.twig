{% block sw_media_display_options %}
{% block sw_media_display_options_presentation %}
<mt-select
    v-if="!hidePresentation"
    name="presentation"
    small
    :options="presentationOptions"
    :label="$t('sw-media.presentation.labelPresentation')"
    class="sw-media-display-options__label-presentation"
    :model-value="presentation"
    :disabled="disabled"
    @update:model-value="onPresentationChanged"
/>
{% endblock %}

{% block sw_media_display_options_sorting %}
<mt-select
    name="sortType"
    small
    :options="sortOptionsSelect"
    :label="$t('sw-media.sorting.labelSort')"
    class="sw-media-display-options__label-sort"
    :model-value="sortingConCat"
    :disabled="disabled"
    @update:model-value="onSortingChanged"
/>
{% endblock %}
{% endblock %}
