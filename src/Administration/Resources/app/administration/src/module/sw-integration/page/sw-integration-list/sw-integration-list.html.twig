{% block sw_integration_list %}
<sw-page class="sw-integration-list">
    {% block sw_integration_list_smart_bar_header %}
    <template #smart-bar-header>
        {% block sw_integration_list_smart_bar_header_title %}
        <h2>
            {% block sw_integration_list_smart_bar_header_title_text %}
            <span>{{ $t('sw-settings.index.title') }}</span>

            <mt-icon
                name="regular-chevron-right-xs"
                size="12px"
            />

            <span>{{ $t('sw-integration.general.headlineIntegrations') }}</span>
            {% endblock %}
        </h2>
        {% endblock %}
    </template>
    {% endblock %}

    <template #smart-bar-actions>
        {% block sw_integration_list_smart_bar_actions %}
        <mt-button
            v-tooltip.bottom="{
                message: $t('sw-privileges.tooltip.warning'),
                disabled: acl.can('integration.creator'),
                showOnDisabledElements: true
            }"
            class="sw-integration-list__add-integration-action"
            variant="primary"
            :disabled="!acl.can('integration.creator')"
            size="default"
            @click="onCreateIntegration"
        >
            {{ $t('sw-integration.general.buttonCreateIntegration') }}
        </mt-button>
        {% endblock %}
    </template>

    {% block sw_integration_list_content %}
    <template #content>
        <sw-card-view class="sw-integration-list__content">
            {# @deprecated tag:v6.8.0 - Will be removed. #}
            {% block sw_integration_list_introduction %}
            <sw-extension-component-section
                position-identifier="sw-integration-list-introduction"
                :deprecated="true"
            />
            {% endblock %}

            {% block sw_integration_list_overview %}
            <mt-card
                class="sw-integration-list__overview"
                position-identifier="sw-integration-list-overview"
                :is-loading="isLoading"
                :title="$t('sw-integration.general.heroHeadlineIntegrations')"
                :subtitle="$t('sw-integration.general.heroDescriptionIntegrations')"
            >
                {% block sw_integration_list_overview_inner %}
                {% block sw_integration_list_detail_modal %}
                <sw-modal
                    v-if="currentIntegration"
                    size="550px"
                    class="sw-integration-list__detail"
                    :is-loading="isModalLoading"
                    :title="showSecretAccessKey ? $t('sw-integration.detail.detailModalTitle') : $t('sw-integration.detail.detailModalTitleEdit') + ' ' + currentIntegration.label"
                    @modal-close="onCloseDetailModal"
                >
                    {% block sw_integration_list_detail_modal_inner %}
                    {% block sw_integration_list_detail_modal_inner_field_label %}
                    <sw-container
                        columns="2fr 1fr"
                        gap="24px"
                    >
                        <mt-text-field
                            v-model="currentIntegration.label"
                            name="sw-field--currentIntegration-label"
                            :label="$t('sw-integration.detail.labelFieldLabel')"
                            :disabled="!acl.can('integration.editor')"
                        />

                        {% block sw_integration_list_detail_modal_inner_acl_is_admin %}
                        <mt-switch
                            v-model="currentIntegration.admin"
                            name="sw-field--currentIntegration-admin"
                            class="sw-settings-user-detail__grid-is-admin"
                            :label="$t('sw-users-permissions.users.user-detail.labelAdministrator')"
                            :disabled="!acl.can('admin')"
                            bordered
                        />
                        {% endblock %}
                    </sw-container>
                    {% endblock %}

                    {% block sw_integration_list_detail_modal_inner_acl_roles %}
                    <sw-entity-multi-select
                        v-model:entity-collection="currentIntegration.aclRoles"
                        v-tooltip="{
                            showDelay: 300,
                            message: $t('sw-users-permissions.users.user-detail.disabledRoleSelectWarning'),
                            disabled: !currentIntegration.admin || !acl.can('integration.editor')
                        }"
                        name="sw-field--currentIntegration-aclRoles"
                        class="sw-settings-user-detail__grid-aclRoles"
                        :label="$t('sw-users-permissions.users.user-detail.labelRoles')"
                        :disabled="currentIntegration.admin || !acl.can('integration.editor')"
                        label-property="name"
                    />
                    {% endblock %}

                    {% block sw_integration_list_detail_modal_inner_field_accesskey %}
                    <mt-text-field
                        v-model="currentIntegration.accessKey"
                        name="sw-field--currentIntegration-accessKey"
                        :label="$t('sw-integration.detail.idFieldLabel')"
                        :disabled="true"
                        :copyable="true"
                        :copyable-tooltip="true"
                    />
                    {% endblock %}

                    {% block sw_integration_list_detail_modal_inner_field_secretaccesskey %}
                    <template v-if="showSecretAccessKey">
                        <mt-text-field
                            v-if="secretAccessKeyFieldTypeIsText"
                            v-model="currentIntegration.secretAccessKey"
                            name="sw-field--currentIntegration-secretAccessKey"
                            :label="$t('sw-integration.detail.secretFieldLabel')"
                            :disabled="true"
                            :password-toggle-able="false"
                            :copyable="showSecretAccessKey"
                            :copyable-tooltip="true"
                        />

                        <mt-password-field
                            v-if="secretAccessKeyFieldTypeIsPassword"
                            v-model="currentIntegration.secretAccessKey"
                            name="sw-field--currentIntegration-secretAccessKey"
                            :label="$t('sw-integration.detail.secretFieldLabel')"
                            :disabled="true"
                            :password-toggle-able="false"
                            :copyable="showSecretAccessKey"
                            :copyable-tooltip="true"
                        />
                    </template>

                    <mt-button
                        v-if="!showSecretAccessKey"
                        variant="critical"
                        :disabled="!acl.can('integration.editor')"
                        :block="true"
                        @click="onGenerateKeys"
                    >
                        {{ $t('sw-integration.detail.buttonCreateNewApiKeys') }}
                    </mt-button>

                    {% block sw_integration_list_detail_modal_inner_field_helpText %}
                    <div
                        v-if="!showSecretAccessKey"
                        class="sw-integration-list__help-text"
                    >
                        {{ $t('sw-integration.detail.hintCreateNewApiKeys') }}
                    </div>
                    {% endblock %}
                    {% endblock %}

                    {% block sw_integration_list_detail_modal_inner_helptext %}
                    <mt-banner
                        v-if="showSecretAccessKey"
                        variant="attention"
                        class="sw-integration-list__secret-help-text-alert"
                    >
                        {{ $t('sw-integration.detail.secretHelpText') }}
                    </mt-banner>
                    {% endblock %}

                    {% block sw_integration_list_detail_modal_inner_footer %}
                    <template #modal-footer>
                        {% block sw_integration_list_detail_modal_inner_footer_cancel %}
                        <mt-button
                            size="small"
                            :disabled="isModalLoading"
                            variant="secondary"
                            @click="onCloseDetailModal"
                        >
                            {{ $t('global.default.cancel') }}
                        </mt-button>
                        {% endblock %}

                        {% block sw_integration_list_detail_modal_inner_footer_apply %}
                        <mt-button
                            size="small"
                            class="sw-integration-detail-modal__save-action"
                            :disabled="(isModalLoading && !!currentIntegration.label) || !acl.can('integration.editor')"
                            variant="primary"
                            @click="onSaveIntegration"
                        >
                            {{ showSecretAccessKey ? $t('sw-integration.detail.buttonApply') : $t('sw-integration.detail.buttonApplyEdit') }}
                        </mt-button>
                        {% endblock %}
                    </template>
                    {% endblock %}
                    {% endblock %}
                </sw-modal>
                {% endblock %}

                {% block sw_integration_list_mcp_modal %}
                <sw-modal
                    v-if="feature.isActive('MCP_SERVER') && mcpIntegration"
                    class="sw-integration-list__mcp-modal"
                    :title="$t('sw-integration.mcp.modalTitle') + ': ' + mcpIntegration.label"
                    @modal-close="onCloseMcpModal"
                >
                    {% block sw_integration_list_mcp_modal_allowlist %}
                    <sw-integration-mcp-allowlist
                        :allowlist="pendingMcpAllowlist"
                        :is-admin="mcpIntegration.admin"
                        :disabled="!acl.can('integration_mcp.editor')"
                        :granted-privileges="mcpGrantedPrivileges"
                        @update:allowlist="pendingMcpAllowlist = $event"
                    />
                    {% endblock %}

                    {% block sw_integration_list_mcp_modal_footer %}
                    <template #modal-footer>
                        <mt-button
                            size="small"
                            variant="secondary"
                            @click="onCloseMcpModal"
                        >
                            {{ $t('global.default.cancel') }}
                        </mt-button>

                        <mt-button
                            size="small"
                            variant="primary"
                            :disabled="!acl.can('integration_mcp.editor')"
                            @click="onSaveMcpAllowlist"
                        >
                            {{ $t('sw-integration.detail.buttonApplyEdit') }}
                        </mt-button>
                    </template>
                    {% endblock %}
                </sw-modal>
                {% endblock %}

                {% block sw_integration_list_grid %}
                <sw-entity-listing
                    v-if="integrations && integrations.length > 0"
                    :data-source="integrations"
                    :columns="integrationColumns"
                    :repository="integrationRepository"
                    :full-page="false"
                    :compact-mode="false"
                    :allow-column-edit="false"
                    :show-selection="false"
                    :show-settings="false"
                    :allow-view="acl.can('integration.viewer')"
                    :is-loading="isLoading"
                >
                    {% block sw_integration_list_grid_inner_slot_columns_label %}
                    <template #column-label="{ item }">
                        <span class="sw-integration-list__app-icon">
                            <mt-icon
                                name="regular-share"
                                size="12px"
                            />
                        </span>

                        <mt-link
                            v-if="!isAppIntegration(item)"
                            as="a"
                            @click.prevent="onShowDetailModal(item)"
                        >
                            {{ item.label }}
                        </mt-link>

                        <span v-else>{{ item.label }}</span>

                        <mt-badge
                            v-if="item.app"
                            class="sw-integration-list__app-badge"
                            variant="info"
                        >
                            {{ $t('sw-integration.list.labelManagedByApp') }}
                        </mt-badge>
                    </template>
                    {% endblock %}

                    {% block sw_integration_list_grid_inner_slot_columns_writeAccess %}
                    <template #column-writeAccess="{ item }">
                        <mt-badge
                            v-if="item.admin"
                            variant="attention"
                        >
                            {{ $t('sw-users-permissions.users.user-detail.labelAdministrator') }}
                        </mt-badge>

                        <span v-if="!item.admin && item.aclRoles && item.aclRoles.length">
                            <mt-badge
                                v-for="role in item.aclRoles"
                                :key="role.name"
                            >
                                {{ role.name }}
                            </mt-badge>
                        </span>
                    </template>
                    {% endblock %}

                    <template #actions="{ item }">
                        {% block sw_integration_list_grid_inner_slot_columns_actions_edit %}
                        <sw-context-menu-item
                            class="sw_integration_list__edit-action"
                            :disabled="!acl.can('integration.editor') || isAppIntegration(item)"
                            @click="onShowDetailModal(item)"
                        >
                            {{ $t('sw-integration.list.contextMenuEdit') }}
                        </sw-context-menu-item>
                        {% endblock %}

                        {% block sw_integration_list_grid_inner_slot_columns_actions_edit_mcp %}
                        <sw-context-menu-item
                            v-if="feature.isActive('MCP_SERVER')"
                            class="sw_integration_list__edit-mcp-action"
                            :disabled="!acl.can('integration_mcp.editor')"
                            @click="onShowMcpModal(item)"
                        >
                            {{ $t('sw-integration.list.contextMenuEditMcp') }}
                        </sw-context-menu-item>
                        {% endblock %}

                        {% block sw_integration_list_grid_inner_slot_columns_actions_delete %}
                        <sw-context-menu-item
                            class="sw_integration_list__delete-action"
                            variant="danger"
                            :disabled="!acl.can('integration.deleter') || isAppIntegration(item)"
                            @click="showDeleteModal = item.id"
                        >
                            {{ $t('sw-integration.list.contextMenuDelete') }}
                        </sw-context-menu-item>
                        {% endblock %}
                    </template>

                    <template #action-modals="{ item }">
                        {% block sw_integration_list_grid_inner_slot_delete_modal %}
                        <sw-modal
                            v-if="showDeleteModal === item.id"
                            :title="$t('sw-integration.detail.deleteModalTitle')"
                            @modal-close="onCloseDeleteModal"
                        >
                            {% block sw_integration_list_grid_inner_slot_delete_modal_confirmtext %}
                            <p>
                                {{ $t('sw-integration.detail.confirmDelete') }}
                                "{{ item.label }}"
                            </p>
                            {% endblock %}

                            {% block sw_integration_list_grid_inner_slot_delete_modal_footer %}
                            <template #modal-footer>
                                <mt-button
                                    size="small"
                                    variant="secondary"
                                    @click="onCloseDeleteModal"
                                >
                                    {{ $t('global.default.cancel') }}
                                </mt-button>

                                <mt-button
                                    size="small"
                                    variant="critical"
                                    @click="onConfirmDelete(item.id)"
                                >
                                    {{ $t('sw-integration.detail.buttonDelete') }}
                                </mt-button>
                            </template>
                            {% endblock %}
                        </sw-modal>
                        {% endblock %}
                    </template>
                </sw-entity-listing>
                {% endblock %}

                {% block sw_product_list_empty_state %}
                <mt-empty-state
                    v-else
                    :icon="$route.meta.$module.icon"
                    :headline="$t('sw-integration.list.messageEmpty')"
                    :description="$t('sw-integration.list.sublineEmpty')"
                />
                {% endblock %}
                {% endblock %}
            </mt-card>
        {% endblock %}
        </sw-card-view>
        {% endblock %}
    </template>
</sw-page>
{% endblock %}
