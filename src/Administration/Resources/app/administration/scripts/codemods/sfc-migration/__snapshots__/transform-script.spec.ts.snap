exports[`scripts/codemods/sfc-migration/transform-script mixin-component: detects mixins as a blocker and falls back to Options API matches the complete Options API backoff script snapshot 1`] = `
"import listingMixin from 'src/app/mixin/listing.mixin';

Shopware.Component.register('sw-mixin-list', {
    mixins: [
        Shopware.Mixin.getByName('notification'),
        listingMixin,
    ],

    data() {
        return {
            items: [],
            isLoading: false,
        };
    },

    computed: {
        total() {
            return this.items.length;
        },
    },

    methods: {
        async loadItems() {
            this.isLoading = true;
            try {
                this.items = await this.fetchItems();
            } finally {
                this.isLoading = false;
            }
        },

        onNotify() {
            this.createNotificationSuccess({ message: 'Done' });
        },
    },
});"
`;

exports[`scripts/codemods/sfc-migration/transform-script module-level-component: preserves module-level code (scss import, const declarations) matches the complete converted script snapshot 1`] = `
"import './module-level-component.scss';
const { cloneDeep } = Shopware.Utils.object;
const COLORS = ['#FF0000', '#00FF00', '#0000FF'];

const props = defineProps({
        name: {
            type: String,
            required: true,
        },
        items: {
            type: Array,
            required: false,
            default: () => [],
        },
    });

import { createExtendableSetup } from 'src/app/adapter/composition-extension-system';
import { computed } from 'vue';

const {
    clonedItems,
    nameColor,
} = createExtendableSetup(
    {
        name: 'sw-module-level',
        props,
    },
    () => {
        const clonedItems = computed(() => {
            return cloneDeep(props.items);
        });
        const nameColor = computed(() => {
            return COLORS[props.name.length % COLORS.length];
        });

        return {
            public: {
                clonedItems,
                nameColor,
            },
        };
    },
);"
`;

exports[`scripts/codemods/sfc-migration/transform-script simple-component: fully converts inject, data, computed, and methods to Composition API matches the complete converted script snapshot 1`] = `
"const props = defineProps({});
const emit = defineEmits(['save']);

import { createExtendableSetup } from 'src/app/adapter/composition-extension-system';
import { ref, computed, inject } from 'vue';

const {
    repositoryFactory,
    title,
    isLoading,
    description,
    onSave,
} = createExtendableSetup(
    {
        name: 'sw-simple-card',
        props,
    },
    () => {
        const repositoryFactory = inject('repositoryFactory');

        const title = ref('Default Title');
        const isLoading = ref(false);

        const description = computed(() => {
            return \`This is: \${title.value}\`;
        });

        const onSave = () => {
            isLoading.value = true;
            emit('save', title.value);
        };

        return {
            public: {
                repositoryFactory,
                title,
                isLoading,
                description,
                onSave,
            },
        };
    },
);"
`;
