{# @sw-package framework #}

{% block layout_breadcrumb_inner %}
    {% if feature('v6.8.0.0') or feature('BREADCRUMB_REWORK') %}
        {% if breadcrumb and breadcrumb|length > 0 %}
            {% set breadcrumbCollection = breadcrumb %}
        {% elseif not breadcrumbCollection or breadcrumbCollection|length == 0 %}
            {% return %}
        {% endif %}

        {% set activeId = breadcrumbCollection|last.categoryId %}
    {% else %}
        {% if category %}
            {% set breadcrumbCategories = sw_breadcrumb_full(category, context) %}
            {# @deprecated tag:v6.8.0 - Variable `categoryId` will be replaced by `activeId` #}
            {% set categoryId = category.id %}
        {% elseif categoryId %}
            {% set breadcrumbCategories = sw_breadcrumb_full_by_id(categoryId, context) %}
        {% else %}
            {% return %}
        {% endif %}
    {% endif %}

    {% if breadcrumbCategories|length > 0 or (feature('v6.8.0.0') or feature('BREADCRUMB_REWORK')) %}
        {# @deprecated tag:v6.8.0 - Variable `breadcrumbKeys` will be removed #}
        {% set breadcrumbKeys = breadcrumbCategories|keys %}

        {% set breadcrumbDivider = 'url(data:image/svg+xml,' ~ source('@Storefront/assets/icon/solid/arrow-medium-right.svg')|url_encode ~ ')' %}

        {% block layout_breadcrumb_container %}
            <nav aria-label="breadcrumb"{% if feature('v6.8.0.0') or feature('BREADCRUMB_REWORK') %} style="--bs-breadcrumb-divider: {{ breadcrumbDivider }};"{% endif %}>
                {% block layout_breadcrumb_list %}
                    {# @deprecated tag:v6.8.0 - BreadcrumbList microdata replaced by JSON-LD in json-ld-breadcrumb.html.twig. Will be removed. #}
                    <ol class="breadcrumb"
                        {% if not feature('JSON_LD_DATA') %}
                        itemscope
                        itemtype="https://schema.org/BreadcrumbList"
                        {% endif %}>
                        {# @deprecated tag:v6.8.0 - Variable `breadcrumbCategory` will be replaced by `breadcrumb` #}
                        {% for breadcrumbCategory in ((feature('v6.8.0.0') or feature('BREADCRUMB_REWORK')) ? breadcrumbCollection : breadcrumbCategories) %}
                            {% if feature('v6.8.0.0') or feature('BREADCRUMB_REWORK') %}
                                {# @deprecated tag:v6.8.0 - Setting variable `breadcrumb` here will be removed #}
                                {% set breadcrumb = breadcrumbCategory %}

                                {% set categoryId = breadcrumb.categoryId %}
                                {% set type = breadcrumb.type %}
                                {% set name = breadcrumb.name %}
                                {% set categoryUrl = seoUrl('frontend.navigation.page', { navigationId: categoryId }) %}
                                {% set shouldOpenInNewTab = breadcrumb.shouldOpenInNewTab %}
                                {% set isActive = categoryId is same as(activeId) %}
                            {% else %}
                                {# @deprecated tag:v6.8.0 - Variable `key` will be replaced by `categoryId` #}
                                {% set key = breadcrumbCategory.id %}
                                {% set type = breadcrumbCategory.type %}
                                {% set name = breadcrumbCategory.translated.name %}
                                {% set categoryUrl = breadcrumbCategory.seoUrl %}
                                {% set shouldOpenInNewTab = breadcrumbCategory.shouldOpenInNewTab %}
                                {% set isActive = key is same as(categoryId) %}
                            {% endif %}

                            {% block layout_breadcrumb_list_item %}
                                {# @deprecated tag:v6.8.0 - BreadcrumbList ListItem microdata replaced by JSON-LD in json-ld-breadcrumb.html.twig. Will be removed. #}
                                <li class="breadcrumb-item"
                                    {% if isActive %}aria-current="page"{% endif %}
                                    {% if not feature('JSON_LD_DATA') %}
                                    itemprop="itemListElement"
                                    itemscope
                                    itemtype="https://schema.org/ListItem"
                                    {% endif %}>
                                    {% if type == 'folder' %}
                                        {# @deprecated tag:v6.8.0 - BreadcrumbList item microdata replaced by JSON-LD in json-ld-breadcrumb.html.twig. Will be removed. #}
                                        {% if not feature('JSON_LD_DATA') %}
                                            <div itemprop="item">
                                                <div itemprop="name">{{ name }}</div>
                                            </div>
                                        {% else %}
                                            <div>{{ name }}</div>
                                        {% endif %}
                                    {% else %}
                                        {# @deprecated tag:v6.8.0 - BreadcrumbList url microdata replaced by JSON-LD in json-ld-breadcrumb.html.twig. Will be removed. #}
                                        <a href="{{ categoryUrl }}"
                                           class="breadcrumb-link{% if isActive %} is-active{% endif %}"
                                           title="{{ name }}"
                                           {% if shouldOpenInNewTab %}target="_blank"{% endif %}
                                           {% if not feature('JSON_LD_DATA') %}itemprop="item"{% endif %}>
                                            {% if not feature('JSON_LD_DATA') %}
                                                <link itemprop="url"
                                                      href="{{ categoryUrl }}">
                                            {% endif %}
                                            <span class="breadcrumb-title" {% if not feature('JSON_LD_DATA') %}itemprop="name"{% endif %}>{{ name }}</span>
                                        </a>
                                    {% endif %}
                                    {# @deprecated tag:v6.8.0 - BreadcrumbList position microdata replaced by JSON-LD in json-ld-breadcrumb.html.twig. Will be removed. #}
                                    {% if not feature('JSON_LD_DATA') %}
                                        <meta itemprop="position" content="{{ loop.index }}">
                                    {% endif %}
                                </li>
                            {% endblock %}

                            {% if not (feature('v6.8.0.0') or feature('BREADCRUMB_REWORK')) %}
                                {# @deprecated tag:v6.8.0 - Block will be removed, the separator has been moved to a CSS only solution - Extend the `layout_breadcrumb_list_item` block if needed #}
                                {% block layout_breadcrumb_placeholder %}
                                    {% if key != breadcrumbKeys|last %}
                                        <div class="breadcrumb-placeholder" aria-hidden="true">
                                            {% sw_icon 'arrow-medium-right' style { size: 'fluid', pack: 'solid' } %}
                                        </div>
                                    {% endif %}
                                {% endblock %}
                            {% endif %}
                        {% endfor %}
                    </ol>
                {% endblock %}
            </nav>
        {% endblock %}
    {% endif %}
{% endblock %}
