{% block layout_structured_data_breadcrumb %}
    {% if category is defined and category %}
        {% set breadcrumbItems = sw_breadcrumb_full(category, context) %}
    {% elseif categoryId is defined and categoryId %}
        {% set breadcrumbItems = sw_breadcrumb_full_by_id(categoryId, context) %}
    {% endif %}

    {% if breadcrumbItems is defined and breadcrumbItems|length > 0 %}
        {% set itemListElement = [] %}
        {% for breadcrumbCategory in breadcrumbItems %}
            {% set listItem = {
                '@type': 'ListItem',
                position: loop.index,
                name: breadcrumbCategory.translated.name
            } %}
            {% if breadcrumbCategory.seoUrl %}
                {% set listItem = listItem|merge({item: breadcrumbCategory.seoUrl}) %}
            {% endif %}
            {% set itemListElement = itemListElement|merge([listItem]) %}
        {% endfor %}

        {% set breadcrumbData = {
            '@context': 'https://schema.org',
            '@type': 'BreadcrumbList',
            itemListElement: itemListElement
        } %}

        {% block layout_structured_data_breadcrumb_script %}
            <script type="application/ld+json">
            {# ludtwig-ignore twig-json-encode-escape-js #}
            {{ breadcrumbData|json_encode(jsonLdFlags)|raw }}
            </script>
        {% endblock %}
    {% endif %}
{% endblock %}
