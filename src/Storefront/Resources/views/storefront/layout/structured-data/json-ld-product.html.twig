{% block page_product_detail_json_ld %}
    {# Determine availability following the same logic as delivery-information.html.twig #}
    {% set digitalType = constant('Shopware\\Core\\Content\\Product\\ProductDefinition::TYPE_DIGITAL') %}
    {% set isDigitalProduct = page.product.type === digitalType %}

    {% if not page.product.active %}
        {% set availability = 'https://schema.org/LimitedAvailability' %}
    {% elseif page.product.releaseDate and page.product.releaseDate|date('U') > 'now'|date('U') %}
        {% set availability = 'https://schema.org/PreOrder' %}
    {% elseif (page.product.stock >= page.product.minPurchase or (isDigitalProduct and not page.product.isCloseout)) and page.product.deliveryTime %}
        {% set availability = 'https://schema.org/InStock' %}
    {% elseif page.product.isCloseout and page.product.stock < page.product.minPurchase %}
        {% set availability = 'https://schema.org/OutOfStock' %}
    {% elseif page.product.stock < page.product.minPurchase and page.product.deliveryTime and page.product.restockTime %}
        {% set availability = 'https://schema.org/LimitedAvailability' %}
    {% else %}
        {% set availability = 'https://schema.org/InStock' %}
    {% endif %}

    {# Separate media into images and videos; both need distinct schema types #}
    {% set imageUrls = [] %}
    {% set videoItems = [] %}
    {% if page.product.media %}
        {% for productMedia in page.product.media %}
            {% if productMedia.media and productMedia.media.url %}
                {% if productMedia.media.mediaType and productMedia.media.mediaType.name == 'VIDEO' %}
                    {#
                        thumbnailUrl is required by Google for VideoObject. Use the media's own
                        thumbnail if available, otherwise fall back to the product cover image.
                        Skip the video entirely if no thumbnail can be resolved.
                    #}
                    {% set thumbnailUrl = null %}
                    {% if productMedia.media.thumbnails is not empty %}
                        {% set thumbnailUrl = productMedia.media.thumbnails.first.url %}
                    {% elseif page.product.cover and page.product.cover.media and page.product.cover.media.url %}
                        {% set thumbnailUrl = page.product.cover.media.url %}
                    {% endif %}

                    {% if thumbnailUrl %}
                        {% set videoItem = {
                            '@type': 'VideoObject',
                            name: productMedia.media.translated.title ?? productMedia.media.fileName,
                            contentUrl: productMedia.media.url,
                            thumbnailUrl: thumbnailUrl,
                            uploadDate: productMedia.media.createdAt|format_date(pattern='Y-MM-dd')
                        } %}
                        {% if productMedia.media.translated.alt %}
                            {% set videoItem = videoItem|merge({description: productMedia.media.translated.alt}) %}
                        {% endif %}
                        {% set videoItems = videoItems|merge([videoItem]) %}
                    {% endif %}
                {% else %}
                    {% set imageUrls = imageUrls|merge([productMedia.media.url]) %}
                {% endif %}
            {% endif %}
        {% endfor %}
    {% endif %}
    {% if imageUrls|length == 0 and page.product.cover and page.product.cover.media and page.product.cover.media.url %}
        {% set imageUrls = [page.product.cover.media.url] %}
    {% endif %}

    {# Build offers data #}
    {% set productUrl = seoUrl('frontend.detail.page', { productId: page.product.id }) %}
    {% set sellerData = {
        '@type': 'Organization',
        '@id': app.request.schemeAndHttpHost ~ '/#organization',
        name: config('core.basicInformation.shopName')
    } %}

    {% if page.product.calculatedPrices|length > 1 %}
        {% set lowestPrice = false %}
        {% set highestPrice = false %}
        {% for price in page.product.calculatedPrices %}
            {% if lowestPrice is same as(false) or price.unitPrice < lowestPrice %}
                {% set lowestPrice = price.unitPrice %}
            {% endif %}
            {% if highestPrice is same as(false) or price.unitPrice > highestPrice %}
                {% set highestPrice = price.unitPrice %}
            {% endif %}
        {% endfor %}

        {% set offersData = {
            '@type': 'AggregateOffer',
            url: productUrl,
            priceCurrency: context.currency.isoCode,
            lowPrice: lowestPrice,
            highPrice: highestPrice,
            offerCount: page.product.calculatedPrices|length,
            availability: availability,
            itemCondition: 'https://schema.org/NewCondition',
            seller: sellerData
        } %}
    {% else %}
        {% set calculatedPrice = page.product.calculatedPrice %}
        {% if page.product.calculatedPrices|length == 1 %}
            {% set calculatedPrice = page.product.calculatedPrices.first %}
        {% endif %}

        {% set offersData = {
            '@type': 'Offer',
            url: productUrl,
            priceCurrency: context.currency.isoCode,
            price: calculatedPrice.unitPrice,
            availability: availability,
            itemCondition: 'https://schema.org/NewCondition',
            seller: sellerData
        } %}

        {% if page.product.deliveryTime %}
            {% set offersData = offersData|merge({
                shippingDetails: {
                    '@type': 'OfferShippingDetails',
                    deliveryTime: {
                        '@type': 'ShippingDeliveryTime',
                        handlingTime: {
                            '@type': 'QuantitativeValue',
                            minValue: page.product.deliveryTime.min,
                            maxValue: page.product.deliveryTime.max,
                            unitCode: 'DAY'
                        }
                    }
                }
            }) %}
        {% endif %}
    {% endif %}

    {# Build main product data structure #}
    {% set productData = {
        '@context': 'https://schema.org',
        '@type': 'Product',
        '@id': productUrl ~ '#product',
        name: page.product.translated.name,
        sku: page.product.productNumber,
        productID: page.product.id,
        url: productUrl,
        offers: offersData
    } %}

    {% if page.product.translated.description %}
        {% set productData = productData|merge({description: page.product.translated.description|striptags}) %}
    {% endif %}

    {% if imageUrls|length > 0 %}
        {% set productData = productData|merge({image: imageUrls}) %}
    {% endif %}

    {% if videoItems|length > 0 %}
        {% set productData = productData|merge({video: videoItems}) %}
    {% endif %}

    {% if page.product.manufacturer %}
        {% set productData = productData|merge({
            brand: {
                '@type': 'Brand',
                name: page.product.manufacturer.translated.name
            }
        }) %}
    {% endif %}

    {% if page.product.ean %}
        {% set productData = productData|merge({gtin13: page.product.ean}) %}
    {% endif %}

    {% if page.product.manufacturerNumber %}
        {% set productData = productData|merge({mpn: page.product.manufacturerNumber}) %}
    {% endif %}

    {% if page.product.releaseDate %}
        {% set productData = productData|merge({releaseDate: page.product.releaseDate|format_date(pattern='Y-MM-dd')}) %}
    {% endif %}

    {# Dimensions as QuantitativeValue with unitText #}
    {% if page.product.measurements.type('weight') %}
        {% set weightValue = page.product.measurements.type('weight').value %}
        {% set weightUnit = page.product.measurements.type('weight').unit %}
    {% else %}
        {% set weightValue = page.product.weight %}
        {% set weightUnit = 'kg' %}
    {% endif %}
    {% if weightValue and weightValue > 0 %}
        {% set productData = productData|merge({weight: {'@type': 'QuantitativeValue', value: weightValue, unitText: weightUnit} }) %}
    {% endif %}

    {% if page.product.measurements.type('height') %}
        {% set heightValue = page.product.measurements.type('height').value %}
        {% set heightUnit = page.product.measurements.type('height').unit %}
    {% else %}
        {% set heightValue = page.product.height %}
        {% set heightUnit = 'mm' %}
    {% endif %}
    {% if heightValue and heightValue > 0 %}
        {% set productData = productData|merge({height: {'@type': 'QuantitativeValue', value: heightValue, unitText: heightUnit} }) %}
    {% endif %}

    {% if page.product.measurements.type('width') %}
        {% set widthValue = page.product.measurements.type('width').value %}
        {% set widthUnit = page.product.measurements.type('width').unit %}
    {% else %}
        {% set widthValue = page.product.width %}
        {% set widthUnit = 'mm' %}
    {% endif %}
    {% if widthValue and widthValue > 0 %}
        {% set productData = productData|merge({width: {'@type': 'QuantitativeValue', value: widthValue, unitText: widthUnit} }) %}
    {% endif %}

    {% if page.product.measurements.type('length') %}
        {% set lengthValue = page.product.measurements.type('length').value %}
        {% set lengthUnit = page.product.measurements.type('length').unit %}
    {% else %}
        {% set lengthValue = page.product.length %}
        {% set lengthUnit = 'mm' %}
    {% endif %}
    {% if lengthValue and lengthValue > 0 %}
        {% set productData = productData|merge({depth: {'@type': 'QuantitativeValue', value: lengthValue, unitText: lengthUnit} }) %}
    {% endif %}

    {% if page.structuredDataReviews %}
        {% set reviewData = page.structuredDataReviews %}
        {% set reviewCount = reviewData.matrix.totalReviewCount %}

        {% if page.product.ratingAverage and page.product.ratingAverage > 0 and reviewCount > 0 %}
            {% set productData = productData|merge({
                aggregateRating: {
                    '@type': 'AggregateRating',
                    ratingValue: page.product.ratingAverage,
                    ratingCount: reviewCount,
                    bestRating: 5
                }
            }) %}
        {% endif %}

        {% set reviewItems = [] %}
        {% for review in reviewData %}
            {% set reviewItem = {
                '@type': 'Review',
                author: {'@type': 'Person', name: review.externalUser},
                datePublished: review.createdAt|format_date(pattern='Y-MM-dd'),
                reviewRating: {
                    '@type': 'Rating',
                    ratingValue: review.points,
                    bestRating: 5
                }
            } %}
            {% if review.title %}
                {% set reviewItem = reviewItem|merge({name: review.title}) %}
            {% endif %}
            {% if review.content %}
                {% set reviewItem = reviewItem|merge({reviewBody: review.content|striptags}) %}
            {% endif %}
            {% if review.language and review.language.translationCode %}
                {% set reviewItem = reviewItem|merge({inLanguage: review.language.translationCode.code}) %}
            {% endif %}
            {% set reviewItems = reviewItems|merge([reviewItem]) %}
        {% endfor %}

        {% if reviewItems|length > 0 %}
            {% set productData = productData|merge({review: reviewItems}) %}
        {% endif %}
    {% endif %}

    {#
        For variant products (parentId is set), Google's Rich Results requires ProductGroup as the
        top-level entity. The specific variant's pricing/identifier data goes inside hasVariant as
        a Product node. Properties describing the product family (name, description, brand, media,
        reviews) are promoted to the ProductGroup level.

        Simple products (no parentId) keep the standard @type: Product structure unchanged.

        Note: the parent product URL is intentionally not included as `url` on the ProductGroup
        because in Shopware parent product URLs redirect to a variant and are not standalone pages.
        Using it would cause Google to associate the ProductGroup entity with that redirect URL
        rather than treating the variant's Product as the page entity.
    #}
    {% if page.product.parentId %}
        {% set parentUrl = seoUrl('frontend.detail.page', { productId: page.product.parentId }) %}
        {% set savedData = productData %}

        {# Build the variant-specific Product node (identifier and pricing info) #}
        {% set variantProduct = {
            '@type': 'Product',
            '@id': savedData['@id'],
            name: savedData.name,
            sku: savedData.sku,
            productID: savedData.productID,
            url: savedData.url,
            offers: savedData.offers
        } %}
        {% if savedData.gtin13 is defined %}
            {% set variantProduct = variantProduct|merge({gtin13: savedData.gtin13}) %}
        {% endif %}
        {% if savedData.mpn is defined %}
            {% set variantProduct = variantProduct|merge({mpn: savedData.mpn}) %}
        {% endif %}
        {% if savedData.releaseDate is defined %}
            {% set variantProduct = variantProduct|merge({releaseDate: savedData.releaseDate}) %}
        {% endif %}
        {% if savedData.weight is defined %}
            {% set variantProduct = variantProduct|merge({weight: savedData.weight}) %}
        {% endif %}
        {% if savedData.height is defined %}
            {% set variantProduct = variantProduct|merge({height: savedData.height}) %}
        {% endif %}
        {% if savedData.width is defined %}
            {% set variantProduct = variantProduct|merge({width: savedData.width}) %}
        {% endif %}
        {% if savedData.depth is defined %}
            {% set variantProduct = variantProduct|merge({depth: savedData.depth}) %}
        {% endif %}

        {# Rebuild productData as ProductGroup with the variant in hasVariant #}
        {% set productData = {
            '@context': 'https://schema.org',
            '@type': 'ProductGroup',
            '@id': parentUrl ~ '#productgroup',
            name: savedData.name,
            productGroupID: page.product.parentId,
            hasVariant: [variantProduct]
        } %}
        {% if savedData.description is defined %}
            {% set productData = productData|merge({description: savedData.description}) %}
        {% endif %}
        {% if savedData.image is defined %}
            {% set productData = productData|merge({image: savedData.image}) %}
        {% endif %}
        {% if savedData.video is defined %}
            {% set productData = productData|merge({video: savedData.video}) %}
        {% endif %}
        {% if savedData.brand is defined %}
            {% set productData = productData|merge({brand: savedData.brand}) %}
        {% endif %}
        {% if savedData.aggregateRating is defined %}
            {% set productData = productData|merge({aggregateRating: savedData.aggregateRating}) %}
        {% endif %}
        {% if savedData.review is defined %}
            {% set productData = productData|merge({review: savedData.review}) %}
        {% endif %}
    {% endif %}

    {% block page_product_detail_json_ld_script %}
        <script type="application/ld+json">
        {# ludtwig-ignore twig-json-encode-escape-js #}
        {{ productData|json_encode(jsonLdFlags)|raw }}
        </script>
    {% endblock %}
{% endblock %}
