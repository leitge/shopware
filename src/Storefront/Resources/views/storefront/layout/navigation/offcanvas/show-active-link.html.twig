{% set name = item.translated.name %}

{% block layout_navigation_offcanvas_navigation_category_show_active_link %}
    <li class="navigation-offcanvas-list-item">
        {% block layout_navigation_offcanvas_navigation_categories_list_current_category_item_link %}
            {# @deprecated tag:v6.8.0 - SiteNavigationElement url/name microdata removed. Not supported as a rich result. #}
            <a class="nav-item nav-link navigation-offcanvas-link is-current-category"
               href="{{ item.seoUrl }}"
               {% if not feature('JSON_LD_DATA') %}
               itemprop="url"
               {% endif %}
               {% if item.shouldOpenInNewTab %}target="_blank"{% endif %}
               title="{{ name }}">
                {% block layout_navigation_offcanvas_navigation_categories_list_current_category_item_text %}
                    <span {% if not feature('JSON_LD_DATA') %}itemprop="name"{% endif %}>
                    {{ 'general.showCategory'|trans({'%category%': name})|sw_sanitize }}
                </span>
                {% endblock %}
            </a>
        {% endblock %}
    </li>
{% endblock %}
