{% block layout_navigation_offcanvas_navigation_home_link %}
    {# @deprecated tag:v6.8.0 - SiteNavigationElement url/name microdata removed. Not supported as a rich result. #}
    <a class="nav-item nav-link is-home-link navigation-offcanvas-link js-navigation-offcanvas-link"
       href="{{ path('frontend.menu.offcanvas') }}"
       {% if not feature('JSON_LD_DATA') %}
       itemprop="url"
       {% endif %}
       title="{{ 'general.mainMenu'|trans|striptags }}">
        {% block layout_navigation_offcanvas_navigation_home_link_text %}
            <span class="navigation-offcanvas-link-icon js-navigation-offcanvas-loading-icon">
                {% sw_icon 'stack' %}
            </span>
            <span {% if not feature('JSON_LD_DATA') %}itemprop="name"{% endif %}>
                {{ 'general.mainMenu'|trans|sw_sanitize }}
            </span>
        {% endblock %}
    </a>
{% endblock %}
