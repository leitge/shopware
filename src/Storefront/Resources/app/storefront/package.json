{
  "name": "sw-next-storefront",
  "version": "1.0.0",
  "private": true,
  "description": "Storefront Building Pipeline for Shopware Next",
  "keywords": [
    "next",
    "pipeline",
    "storefront",
    "sw"
  ],
  "license": "MIT",
  "scripts": {
    "build:shopware": "vite build --config vite.shopware.config.mts",
    "build:components": "node build/vite/build-components.js",
    "dev:server": "vite --config vite.components.config.mts",
    "development": "NODE_ENV=development webpack --config webpack.config.js",
    "hot": "NODE_ENV=development MODE=hot webpack-dev-server --config webpack.config.js",
    "hot-proxy": "NODE_ENV=development MODE=hot node ./build/start-hot-reload.js",
    "lint": "eslint --no-error-on-unmatched-pattern --report-unused-disable-directives ./src --cache && stylelint --config stylelint.config.js ./src/scss --cache",
    "lint-fix": "npm run lint:js:fix && npm run lint:scss-fix",
    "lint:js": "eslint --no-error-on-unmatched-pattern --report-unused-disable-directives ./src ./build && (cd ../.. && eslint --no-error-on-unmatched-pattern --config ./app/storefront/eslint.config.js --report-unused-disable-directives views/components)",
    "lint:js:fix": "eslint --no-error-on-unmatched-pattern --fix --report-unused-disable-directives ./src ./build && (cd ../.. && eslint --no-error-on-unmatched-pattern --fix --config ./app/storefront/eslint.config.js --report-unused-disable-directives views/components)",
    "lint:scss": "stylelint --config stylelint.config.js ./src/scss --cache",
    "lint:scss-fix": "npm run lint:scss -- --fix",
    "production": "NODE_ENV=production webpack --config webpack.config.js && npm run build:shopware && npm run build:components",
    "unit": "jest --config jest.config.js --ci",
    "unit-watch": "jest --config jest.config.js --watch",
    "unit:components": "vitest run --config vitest.config.mts",
    "unit:components:watch": "vitest --config vitest.config.mts",
    "unit:components:coverage": "vitest run --coverage --config vitest.config.mts",
    "postinstall": "patch-package && node build/link-component-node-modules.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@popperjs/core": "2.11.8",
    "@shopware-ag/dive": "2.3.4",
    "@swc/core": "1.10.14",
    "autoprefixer": "10.4.13",
    "bootstrap": "5.3.8",
    "copy-webpack-plugin": "14.0.0",
    "core-js": "3.40.0",
    "css-loader": "7.1.2",
    "deepmerge": "4.3.1",
    "events": "3.3.0",
    "file-loader": "6.2.0",
    "flatpickr": "4.6.13",
    "fs-extra": "11.3.0",
    "hammerjs": "2.0.8",
    "history": "4.10.1",
    "mini-css-extract-plugin": "2.9.2",
    "patch-package": "8.0.0",
    "postcss-loader": "8.1.1",
    "postcss-pxtorem": "6.1.0",
    "qrcode": "1.5.4",
    "sass": "1.83.4",
    "sass-loader": "16.0.4",
    "style-loader": "4.0.0",
    "swc-loader": "0.2.6",
    "terser-webpack-plugin": "5.3.17",
    "tiny-slider": "2.9.4",
    "tinyglobby": "0.2.16",
    "typescript": "5.7.3",
    "vite": "8.0.9",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1",
    "webpack-merge": "6.0.1",
    "webpackbar": "7.0.0"
  },
  "devDependencies": {
    "@babel/cli": "7.23.4",
    "@babel/core": "7.23.7",
    "@babel/plugin-proposal-decorators": "7.23.7",
    "@babel/preset-env": "7.23.7",
    "@babel/preset-typescript": "7.23.3",
    "@eslint/js": "9.39.3",
    "@storybook/addon-docs": "10.4.0",
    "@storybook/addon-webpack5-compiler-swc": "4.0.3",
    "@storybook/server-webpack5": "10.4.0",
    "@types/jest": "30.0.0",
    "@vitest/coverage-v8": "4.1.4",
    "chokidar": "3.5.3",
    "eslint": "9.39.3",
    "eslint-plugin-jest": "29.15.0",
    "eslint-plugin-storybook": "10.4.0",
    "globals": "17.3.0",
    "happy-dom": "20.8.9",
    "http-proxy-middleware": "3.0.5",
    "jest": "30.1.3",
    "jest-environment-jsdom": "30.2.0",
    "jest-junit": "16.0.0",
    "license-checker-rseidelsohn": "4.3.0",
    "lodash.get": "4.4.2",
    "prettier": "3.5.3",
    "sass-embedded": "1.97.3",
    "storybook": "10.4.0",
    "stylelint": "16.16.0",
    "stylelint-config-recommended-scss": "14.1.0",
    "stylelint-junit-formatter": "0.2.2",
    "stylelint-prettier": "5.0.3",
    "typescript-eslint": "8.59.4",
    "vitest": "4.1.4",
    "webpack-dev-server": "5.2.4",
    "xml2js": "0.6.2"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">=11.8.0"
  },
  "overrides": {
    "@babel/plugin-transform-modules-systemjs": "7.29.4",
    "fast-uri": "3.1.2",
    "postcss": "8.5.14",
    "tmp": "0.2.5",
    "qs": "6.14.2",
    "minimatch": "10.2.5",
    "brace-expansion": "5.0.6",
    "serialize-javascript": "7.0.5",
    "test-exclude": "8.0.0",
    "@babel/runtime": "7.28.6",
    "ajv@^8": "8.18.0",
    "follow-redirects": "1.16.0",
    "flatted": "3.4.2",
    "lodash": "4.18.1",
    "path-to-regexp": "0.1.13",
    "picomatch@2": "2.3.2",
    "picomatch@4": "4.0.4"
  }
}
