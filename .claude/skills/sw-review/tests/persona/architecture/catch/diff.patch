+    public function enrichLineItemsWithLatestPrices(Cart $cart, SalesChannelContext $context): Cart
+    {
+        foreach ($cart->getLineItems() as $lineItem) {
+            $criteria = new Criteria([$lineItem->getReferencedId()]);
+            $product = $this->productRepository->search($criteria, $context->getContext())->first();
+
+            if ($product === null) {
+                continue;
+            }
+
+            $lineItem->setPrice($product->getCalculatedPrice());
+        }
+
+        return $cart;
+    }
